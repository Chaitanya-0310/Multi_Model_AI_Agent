# ── LLM Provider ──────────────────────────────────────────────────────────────
# Set to "groq" for higher free-tier rate limits (recommended for development)
# Set to "gemini" (default) to use Google Gemini 2.5 Flash
LLM_PROVIDER=groq

# ── Groq (open-source models, generous free tier) ─────────────────────────────
# Get your free API key at: https://console.groq.com
# Default model: llama-3.3-70b-versatile (best quality on free tier)
# Other options: llama-3.1-8b-instant (faster), mixtral-8x7b-32768
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Google Gemini (used when LLM_PROVIDER=gemini) ─────────────────────────────
# Get your API key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ── Langfuse Observability (optional) ─────────────────────────────────────────
# Get your keys at: https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Google Workspace Publishing (optional) ────────────────────────────────────
# Option A — OAuth Desktop App (recommended)
GDRIVE_CLIENT_ID=
GDRIVE_CLIENT_SECRET=
# Option B — Service Account JSON (single-line, escaped)
GOOGLE_SERVICE_ACCOUNT_INFO=
